# Copy to .env.local and fill in.

# Groq API key — free from https://console.groq.com
# Without a key the app still runs using a mock generator.
GROQ_API_KEY=

# libSQL / Turso database. Locally you can leave these unset and the app
# falls back to a local SQLite file (file:studycraft.db). For Vercel (or any
# serverless host) you MUST point at a hosted Turso DB:
#   turso db create studycraft
#   turso db show studycraft --url        -> TURSO_DATABASE_URL
#   turso db tokens create studycraft     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
